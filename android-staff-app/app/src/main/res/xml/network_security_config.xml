<?xml version="1.0" encoding="utf-8"?>
<!-- Release/default: HTTPS only, system trust anchors. No cleartext. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
